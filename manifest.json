{
  "manifest_version": 2,
  "name": "PlexiCopy",
  "version": "1.1",
  "description": "Clean up Perplexity answers: hide UI citations and copy perfectly cleaned Markdown or plain text with one click.",
  "browser_specific_settings": {
    "gecko": {
      "id": "plexicopy@local",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
    }
  },
  "icons": {
    "32": "icons/icon.svg",
    "64": "icons/icon.svg",
    "128": "icons/icon.svg"
  },
  "permissions": [
    "activeTab",
    "clipboardRead",
    "clipboardWrite",
    "storage"
  ],
  "browser_action": {
    "default_title": "PlexiCopy Settings",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "*://www.perplexity.ai/*",
        "*://perplexity.ai/*"
      ],
      "js": [
        "content.js"
      ]
    }
  ]
}